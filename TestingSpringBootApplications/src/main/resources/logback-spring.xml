<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Define the Console Appender -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <!-- [Time] [Level] [CorrelationID] [Thread] [Logger] - [Message] -->
            <pattern>%d{yyyy-MM-dd HH:mm:ss} [%thread] %highlight(%-5level) [%X{correlationId}] %cyan(%logger{36}) - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- [Optional] Define a File Appender for Production (uncomment to use) -->
    <!--
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/application.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/application.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder" />
    </appender>
    -->

    <!-- Set default logging level for the ROOT -->
    <root level="INFO">
        <appender-ref ref="CONSOLE" />
    </root>

    <!-- Set specific package logging level -->
    <logger name="com.example.testingspringbootapplications" level="DEBUG" additivity="false">
        <appender-ref ref="CONSOLE" />
    </logger>

</configuration>
